---
// Instant client-side redirect with language detection
// Static build: meta refresh defaults to /es/, JS upgrades to detected language
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/es/" />
    <link rel="canonical" href="https://joledev.com/es/" />
    <title>JoleDev</title>
    <script is:inline>
      var lang = (navigator.language || '').split('-')[0];
      window.location.replace('/' + (lang === 'en' ? 'en' : 'es') + '/');
    </script>
    <style>
      html, body { margin: 0; padding: 0; background: #0a0a0a; height: 100vh; overflow: hidden; }
    </style>
  </head>
  <body></body>
</html>
